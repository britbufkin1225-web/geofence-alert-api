# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="file:./dev.db"

# API Configuration
API_PREFIX=api
API_VERSION=v1

# Security
API_KEY=change-this-development-api-key

# Geofence Defaults
DEFAULT_GEOFENCE_RADIUS_METERS=100
MAX_GEOFENCE_RADIUS_METERS=5000

# Logging
LOG_LEVEL=debug